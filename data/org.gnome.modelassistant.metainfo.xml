<component type="desktop-application">
  <id>org.gnome.modelassistant</id>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <name>Model Assistant</name>
  <summary>Launch local AI model runtimes</summary>
  <description>
    <p>Model Assistant is a GNOME desktop application for launching local AI model runtimes from a MODELS_ROOT layout.</p>
    <p>It validates the runner environment at startup, presents models in a sidebar, and lets each model choose a runtime and mode before launch.</p>
  </description>
  <launchable type="desktop-id">org.gnome.modelassistant.desktop</launchable>
  <url type="homepage">https://github.com/fxzxmicah/model-assistant</url>
  <url type="bugtracker">https://github.com/fxzxmicah/model-assistant/issues</url>
  <provides>
    <binary>model-assistant</binary>
  </provides>
  <developer id="org.gnome">
